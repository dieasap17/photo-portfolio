# Videos: immutable, 1-year cache (never change once deployed)
/videos/*
  Cache-Control: public, max-age=31536000, immutable

# Cover thumbnails: immutable, 1-year cache
/covers/*
  Cache-Control: public, max-age=31536000, immutable

# Hashed build assets (JS/CSS): immutable, 1-year cache
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Avatar: 1-week cache (may update occasionally)
/avatar.webp
  Cache-Control: public, max-age=604800

# HTML entry point: validate on every request, no long-term cache
/index.html
  Cache-Control: public, max-age=0, must-revalidate
